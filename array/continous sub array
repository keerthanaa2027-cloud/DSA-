 bool checkSubarraySum(vector<int>& nums, int k) {
         unordered_map<int, int> mp;

        // remainder 0 is considered before the array starts
        mp[0] = -1;

        int prefixSum = 0;

        for (int i = 0; i < nums.size(); i++) {

            prefixSum += nums[i];

            int rem = prefixSum % k;

            if (mp.find(rem) != mp.end()) {

                // Same remainder found before
                if (i - mp[rem] > 1)
                    return true;

            } else {

                // First time seeing this remainder
                mp[rem] = i;
            }
        }

        return false;
        
    }
};
