 int majorityElement(vector<int>& nums) {
        unordered_map<int,int>map;
        for( int values : nums){
            map[values]++;
        }
        for(auto &pair:map){
            if(pair.second>nums.size()/2){
                return pair.first;
            }
        }
        return -1;
        
    }
    
};
