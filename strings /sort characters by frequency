 unordered_map<char, int> freq;
    for(char c : s) freq[c]++;

    vector<string> bucket(s.size() + 1);

    for(auto &p : freq) {
        bucket[p.second] += string(p.second, p.first);
    }

    string result = "";
    for(int i = s.size(); i >= 1; i--) {
        result += bucket[i];
    }
    return result;

        
