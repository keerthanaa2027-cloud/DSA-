string largeOddNum(string& num){
        for(int i = num.size()-1; i >= 0; i--) {
            if((num[i]-'0')%2 != 0) {
                string ans = num.substr(0 , i+1);

                int j = 0;
                while(j < ans.size() && ans[j] == '0') {
                    j++;
                }

                return ans.substr(j);
            }
        }
        return "";
    }
};
